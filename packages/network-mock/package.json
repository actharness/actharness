{
  "name": "@actharness/network-mock",
  "version": "0.1.0",
  "license": "MIT",
  "description": "actharness network mock layer — shared registry, Node IPC path, proxy-based MITM path for all shell types",
  "repository": {
    "type": "git",
    "url": "https://github.com/actharness/actharness",
    "directory": "packages/network-mock"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./bootstrap-network": "./src/sandbox-bootstrap-network.mjs"
  },
  "files": [
    "dist",
    "src/sandbox-bootstrap-network.mjs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@actharness/core": "workspace:*",
    "@actharness/types": "workspace:*",
    "@mswjs/interceptors": "^0.41.9",
    "@peculiar/x509": "^1.12.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
