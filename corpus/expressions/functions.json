{
  "cases": [
    { "expr": "contains('search', 'item')", "expect": false },
    { "expr": "cOnTaInS('Hello', 'll')", "expect": true, "_pins": "function name case-insensitive" },
    { "expr": "contains('HELLO', 'll')", "expect": true, "_pins": "substring case-insensitive" },
    { "expr": "contains('3.141592', 3.14)", "expect": true, "_pins": "number arg -> string" },
    { "expr": "contains(3.141592, '3.14')", "expect": true, "_pins": "number coerced to string for substring search" },
    { "expr": "contains(3.141592, 3.14)", "expect": true, "_pins": "number haystack, number needle" },
    { "expr": "contains(true, 'u')", "expect": true },
    { "expr": "contains(null, '')", "expect": true },
    { "expr": "contains(fromJSON('[\"first\",\"second\"]'), 'first')", "expect": true },
    { "expr": "contains(fromJSON('[null,\"second\"]'), '')", "expect": true, "_pins": "array element loose-== : null == ''" },
    { "expr": "contains(fromJSON('[\"\"  ,\"second\"]'), null)", "expect": true, "_pins": "array element loose-== : '' == null" },
    { "expr": "contains(fromJSON('[true,\"second\"]'), 'true')", "expect": false, "_pins": "bool vs string -> number -> 1==NaN -> false" },
    { "expr": "contains(fromJSON('[\"true\",\"second\"]'), true)", "expect": false, "_pins": "string vs bool -> number -> NaN==1 -> false" },
    { "expr": "contains(fromJSON('[3.14,\"second\"]'), '3.14')", "expect": true, "_pins": "number element, string needle via coercion" },
    { "expr": "contains(fromJSON('[3.14,\"second\"]'), 3.14)", "expect": true },
    { "expr": "contains(fromJSON('[\"\"  ,\"second\"]'), fromJSON('[]'))", "expect": false, "_pins": "array needle -> reference equality -> false" },
    { "expr": "contains(fromJSON('[\"\"  ,\"second\"]'), fromJSON('{}'))", "expect": false, "_pins": "object needle -> reference equality -> false" },
    { "expr": "contains(fromJSON('[{ \"first\": { \"result\": \"success\" }},{ \"second\": { \"result\": \"success\" }}]').first.result, 'success')", "expect": true, "_pins": "nested property on array of objects" },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\" },{ \"result\": \"success\" }]').*.result, 'failure')", "expect": true },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\" },{ \"result\": \"success\" }]').*.result, 'success')", "expect": true, "_pins": "wildcard + contains" },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\" },{ \"result\": \"success\" }]').*.result, 'notthere')", "expect": false },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\", \"outputs\": { \"key\": \"val1\" } },{ \"result\": \"success\", \"outputs\": { \"key\": \"val2\" } }]').*.outputs.key, 'val1')", "expect": true, "_pins": "deep wildcard chain" },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\", \"outputs\": { \"key\": \"val1\" } },{ \"result\": \"success\", \"outputs\": { \"key\": \"val2\" } }]').*.outputs.key, 'val2')", "expect": true },
    { "expr": "contains(fromJSON('[{ \"result\": \"failure\", \"outputs\": { \"key\": \"val1\" } },{ \"result\": \"success\", \"outputs\": { \"key\": \"val2\" } }]').*.outputs.key, 'missing')", "expect": false },

    { "expr": "startsWith('search', 'se')", "expect": true },
    { "expr": "startsWith('search', 'sa')", "expect": false },
    { "expr": "startsWith('123search', '123s')", "expect": true },
    { "expr": "startsWith(123, 's')", "expect": false },
    { "expr": "startsWith(123, '12')", "expect": true },
    { "expr": "startsWith('123', 12)", "expect": true },
    { "expr": "startsWith(null, '42')", "expect": false },
    { "expr": "startsWith('null', null)", "expect": true, "_pins": "null -> '' ; everything startsWith ''" },
    { "expr": "startsWith('null', '')", "expect": true, "_pins": "every string startsWith empty string" },

    { "expr": "endsWith('search', 'ch')", "expect": true },
    { "expr": "endsWith('search', 'sa')", "expect": false },
    { "expr": "endsWith('search123s', '123s')", "expect": true },
    { "expr": "endsWith(123, 's')", "expect": false },
    { "expr": "endsWith(123, '23')", "expect": true },
    { "expr": "endsWith('123', 23)", "expect": true },
    { "expr": "endsWith(null, '42')", "expect": false },
    { "expr": "endsWith('null', null)", "expect": true, "_pins": "null -> ''; everything endsWith ''" },
    { "expr": "endsWith('null', '')", "expect": true, "_pins": "every string endsWith empty string" },

    { "expr": "format('text')", "expect": "text" },
    { "expr": "format('Hello {0} {1} {2}!', 'Mona', 'the', 'Octocat')", "expect": "Hello Mona the Octocat!" },
    { "expr": "format('{{Hello {0} {1} {2}!}}', 'Mona', 'the', 'Octocat')", "expect": "{Hello Mona the Octocat!}", "_pins": "{{ and }} are escaped braces" },
    { "expr": "format('{{0}}', 'test')", "expect": "{0}" },
    { "expr": "format('{{{0}}}', 'test')", "expect": "{test}" },
    { "expr": "format('}}')", "expect": "}" },
    { "expr": "format(true)", "expect": "true", "_pins": "non-string format arg coerced to string" },
    { "expr": "format('Hello \"{0}\" {1} {2} {3} {4}', null, true, -3.14, NaN, Infinity)", "expect": "Hello \"\" true -3.14 NaN Infinity", "_pins": "null -> ''; special numbers render as their string forms" },
    { "expr": "format('Hello \"{0}\" {1} {2}', fromJSON('[0, true, \"abc\"]'), fromJSON('[{\"a\":1}]'), fromJSON('{\"a\":{\"b\":1}}'))", "expect": "Hello \"Array\" Array Object", "_pins": "array -> 'Array'; object -> 'Object'" },
    { "expr": "format('echo Hello {0} ${{Test}}', github.undefined_property)", "expect": "echo Hello  ${Test}",
      "context": { "github": {} },
      "_pins": "${{...}} in format string: {{ -> {, }} -> }; undefined property -> ''" },
    { "expr": "format('{0} {1} {2} {3}', 1.0, 1.1, 1234567890.0, 12345678901234567890.0)", "expect": "1 1.1 1234567890 1.23456789012346E+19", "_pins": "G15: integral doubles drop .0; large float -> scientific notation" },
    { "expr": "format('{0}}', '{1}', 'World')", "error": "Closing bracket without opening one" },
    { "expr": "format('{0', '{1}', 'World')", "error": "Unclosed brackets" },
    { "expr": "format('{2}', '{1}', 'World')", "error": "references more arguments than were supplied" },
    { "expr": "format('{2147483648}')", "error": "references more arguments than were supplied",
      "_pins": "index > int32.MaxValue: runner says 'invalid format string'; our evaluator falls through to out-of-bounds; both throw — error substring uses our message" },

    { "expr": "join(fromJSON('[\"a\", \"b\"]'), ',')", "expect": "a,b" },
    { "expr": "join('string', ',')", "expect": "string" },
    { "expr": "join(1, ',')", "expect": "1" },
    { "expr": "join(null, ',')", "expect": "" },
    { "expr": "join(fromJSON('[\"a\", \"b\", null]'), null)", "expect": "ab" },
    { "expr": "join(fromJSON('[\"a\", \"b\"]'))", "expect": "a,b" },
    { "expr": "join(fromJSON('[\"a\", \"b\", null]'), 1)", "expect": "a1b1" },

    { "expr": "toJSON(null)", "expect": "null" },
    { "expr": "toJSON(env)", "context": { "env": { "key": "value" } }, "expect": "{\n  \"key\": \"value\"\n}", "_pins": "pretty-print 2-space" },
    { "expr": "fromJSON('{\"foo\":\"bar\"}')", "expect": { "foo": "bar" } },

    { "expr": "hashFiles('**/non-extant-files')", "expect": "", "_pins": "no match -> ''" },
    { "expr": "hashFiles('**/non-extant-files', '**/more-non-extant-files')", "expect": "", "_pins": "multi-pattern, no match -> ''" }
  ]
}
